# Environment Variables — Utility Manager Agent
# Copy this file to .env and fill in your values.
# Never commit .env to version control.

# ─── Augos Authentication ────────────────────────────────────────────────────
# Mode 1 (recommended): Session token — no password required.
# Run: python3 scripts/get_session_token.py  ← This does it automatically.
# Tokens last 7–30 days. Re-run the script if you see 401 errors.
AUGOS_SESSION_ID=your_session_id_here

# Mode 2 (optional, for fully autonomous overnight operation):
# Only needed if AUGOS_SESSION_ID is left blank.
# AUGOS_EMAIL=your_email@augos.io
# AUGOS_PASSWORD=your_augos_password

# ─── Email Recipients ────────────────────────────────────────────────────────
# Daily brief + weekly technical summary
CHIEF_ENGINEER_EMAIL=engineer@oneandonlycapetown.com

# Weekly executive summary + monthly report
GM_EMAIL=generalmanager@oneandonlycapetown.com

# Monthly financial report
FINANCE_EMAIL=finance@oneandonlycapetown.com

# Monthly + quarterly sustainability reports
SUSTAINABILITY_EMAIL=sustainability@oneandonlycapetown.com

# ─── Development / Testing Mode ────────────────────────────────────────────
# DEV_MODE=true: ALL emails route to DEV_EMAIL regardless of intended recipient.
# Each email shows an amber banner indicating the intended persona and recipient.
# Set DEV_MODE=false only when explicitly authorising live delivery.
DEV_MODE=true
DEV_EMAIL=tim@augos.io

# Approved domains for live delivery (augos.io is always permitted).
# Add only with explicit authorisation. Comma-separated.
# Example: APPROVED_EMAIL_DOMAINS=oneandonlycapetown.com,kerzner.com
APPROVED_EMAIL_DOMAINS=


# Follow setup guide: knowledge/SETUP_GMAIL_API.md
GMAIL_SERVICE_ACCOUNT_PATH=credentials/service_account.json
GMAIL_DELEGATE_ADDRESS=tim@yourdomain.com    # Existing user the SA impersonates

# Display name on outgoing emails
EMAIL_FROM_NAME=Utility Intelligence Manager | One & Only Cape Town

# ─── Google Cloud (for Vertex AI deployment) ───────────────────────────────
GOOGLE_CLOUD_PROJECT=augos-core-data
GOOGLE_CLOUD_REGION=us-central1

# ─── Logging ────────────────────────────────────────────────────────────────
LOG_LEVEL=INFO
