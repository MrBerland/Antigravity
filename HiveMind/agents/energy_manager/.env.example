# Environment variables for Energy Manager Agent
# Copy this file to .env and fill in your values

# Augos Session ID (required)
# To get this:
# 1. Log in to https://live.augos.io
# 2. Open DevTools (F12) -> Application tab -> Session Storage
# 3. Find the 'utsdb' key under live.augos.io
# 4. Copy the value of 'augosportal-sid' from the JSON
AUGOS_SESSION_ID=your_session_id_here

# Google Cloud Project (for deployment)
GOOGLE_CLOUD_PROJECT=augos-core-data

# Optional: Logging level
LOG_LEVEL=INFO
